---
import type { BaseLayoutProps } from "./BaseLayout.types";
import { themeInitScript } from "../scripts/theme-init.ts";
import FolderTreeSidebar from "../components/FolderTreeSidebar.astro";
import "../styles/base.css";

const {
  title,
  description,
  lang = "ko",
  canonicalUrl,
  ogType = "website",
  siteName,
  sidebarRoots,
  currentSlug,
  repoUrl,
} = Astro.props as BaseLayoutProps;

const hasSidebar = sidebarRoots !== undefined && sidebarRoots.length > 0;
// `LICENSE` lives at the repo root on the default branch — concatenating to
// `/blob/main/LICENSE` is the GitHub convention. We accept any URL shape via
// the schema (it's just a string), so this only produces a usable link when
// `repoUrl` is a GitHub-style URL. For non-GitHub hosts the "MIT" link will
// 404; theme adopters who self-host elsewhere can override the footer in their
// own layout rather than us guessing the host's path conventions.
const licenseUrl =
  repoUrl !== undefined ? `${repoUrl.replace(/\/$/, "")}/blob/main/LICENSE` : undefined;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {canonicalUrl && (
      <>
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:type" content={ogType} />
        <meta property="og:title" content={title} />
        {description && <meta property="og:description" content={description} />}
        {siteName && <meta property="og:site_name" content={siteName} />}
      </>
    )}
    {/* Preload the two fonts visible above-the-fold (sans body + serif headings).
        Mono / Korean fonts load lazily via swap to keep the critical path lean. */}
    <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/SourceSerif4Variable-Roman.woff2" as="font" type="font/woff2" crossorigin />
    <script is:inline set:html={themeInitScript}></script>
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">본문으로 건너뛰기</a>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href="/">noteforge</a>
        <nav class="site-nav" aria-label="주 메뉴">
          <ul role="list">
            <li><a href="/">notes</a></li>
            <li><a href="/tags">tags</a></li>
            <li><a href="/graph">graph</a></li>
          </ul>
        </nav>
        <div class="header-actions">
          <button id="theme-toggle" type="button" class="icon-button" aria-label="테마 전환">
            {/* Sun + moon: CSS swaps the visible one based on data-theme / prefers-color-scheme. */}
            <svg class="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
            </svg>
            <svg class="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
          </button>
          {/* Mobile menu uses <details> — JS-less toggle; CSS hides it on md+. */}
          <details class="mobile-menu">
            <summary aria-label="메뉴">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 6h18M3 12h18M3 18h18" />
              </svg>
            </summary>
            <nav class="mobile-menu__panel" aria-label="모바일 메뉴">
              <ul role="list">
                <li><a href="/">notes</a></li>
                <li><a href="/tags">tags</a></li>
                <li><a href="/graph">graph</a></li>
              </ul>
              {hasSidebar && (
                <FolderTreeSidebar
                  roots={sidebarRoots!}
                  currentSlug={currentSlug}
                  ariaLabel="모바일 폴더 탐색"
                />
              )}
            </nav>
          </details>
        </div>
      </div>
    </header>
    {hasSidebar ? (
      <div class="site-shell">
        <FolderTreeSidebar roots={sidebarRoots!} currentSlug={currentSlug} />
        <main id="main" class="site-main">
          <slot />
        </main>
      </div>
    ) : (
      <main id="main" class="site-main">
        <slot />
      </main>
    )}
    <footer class="site-footer">
      <div class="site-footer__inner">
        <span>© 2026 — noteforge</span>
        {repoUrl && (
          <a href={repoUrl} target="_blank" rel="noopener noreferrer">source</a>
        )}
        {licenseUrl && (
          <a href={licenseUrl} target="_blank" rel="noopener noreferrer">MIT</a>
        )}
      </div>
    </footer>
    {/* Theme toggle handler — bundled module, not inline. The resolve+set
        logic lives in `theme-init.ts` so it stays single-source-of-truth with
        the FOUC-prevention `themeInitScript` block above; this script just
        binds it to the button. */}
    <script>
      import { bindThemeToggle } from "../scripts/theme-init.ts";
      const btn = document.getElementById("theme-toggle");
      if (btn !== null) {
        bindThemeToggle(
          btn,
          document.documentElement,
          window.localStorage,
          window.matchMedia("(prefers-color-scheme: dark)"),
        );
      }
    </script>
  </body>
</html>
