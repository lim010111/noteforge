---
import type { BaseLayoutProps } from "./BaseLayout.types";
import { themeInitScript } from "../scripts/theme-init.ts";
import Sidebar from "../components/Sidebar.astro";
import TableOfContents from "../components/TableOfContents.astro";
import "../styles/base.css";

const {
  title,
  description,
  lang = "ko",
  canonicalUrl,
  ogType = "website",
  siteName,
  sidebar,
  tableOfContents,
} = Astro.props as BaseLayoutProps;
const hasSidebar = sidebar !== undefined;
const hasToc = tableOfContents !== undefined;
const shellClasses = [
  "site-shell",
  hasSidebar ? "site-shell--with-sidebar" : null,
  hasToc ? "site-shell--with-toc" : null,
]
  .filter((c): c is string => c !== null)
  .join(" ");
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {canonicalUrl && (
      <>
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:type" content={ogType} />
        <meta property="og:title" content={title} />
        {description && <meta property="og:description" content={description} />}
        {siteName && <meta property="og:site_name" content={siteName} />}
      </>
    )}
    {/* v0.5: a single Korean+Latin family covers everything above-the-fold,
        so only NotoSansKR-Regular needs preloading. Bold (used by headings)
        stays lazy — the visible-on-load text is body copy, and FOUT on
        headings is a one-paint flash that's preferable to two preload
        round-trips on every page. */}
    <link rel="preload" href="/fonts/NotoSansKR-Regular.woff2" as="font" type="font/woff2" crossorigin />
    {/* KaTeX stylesheet — vendored under /styles/katex/ by scripts/
        vendor-katex.mjs (run by the apps/blog prebuild hook). Loaded as a
        regular stylesheet rather than preloaded because pages without math
        shouldn't pay the bandwidth; modern browsers already prioritise
        late-discovered render-blocking CSS aggressively. */}
    <link rel="stylesheet" href="/styles/katex/katex.min.css" />
    <script is:inline set:html={themeInitScript}></script>
    <slot name="head" />
  </head>
  <body class:list={[hasSidebar && "has-sidebar", hasToc && "has-toc"]}>
    <a class="skip-link" href="#main">본문으로 건너뛰기</a>
    {/* Sticky-header shadow sentinel — a 1px tracer just above the header.
        When it leaves the viewport (i.e. the header is "stuck"), CSS adds
        `--shadow-1` to the header. Pure CSS can't detect sticky state, so a
        ~10-line IntersectionObserver is the smallest viable shim. See
        docs/adr/0014-sticky-header-shadow-on-scroll.md for the contract
        rationale. */}
    <div class="site-header__sentinel" aria-hidden="true"></div>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href="/">{siteName}</a>
        <nav class="site-nav" aria-label="주 메뉴">
          <ul role="list">
            <li><a href="/">Home</a></li>
            <li><a href="/categories/">Categories</a></li>
          </ul>
        </nav>
        <div class="header-actions">
          <button id="theme-toggle" type="button" class="icon-button theme-toggle" aria-label="테마 전환">
            {/* Sun + moon overlap inside the button. CSS fades opacity + rotates
                ~12° between the two based on data-theme / prefers-color-scheme.
                Both SVGs remain in the DOM; only their visibility changes. */}
            <svg class="theme-icon theme-icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
            </svg>
            <svg class="theme-icon theme-icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
          </button>
          {/* Mobile menu uses <details> — JS-less toggle; CSS hides it on md+.
              When `sidebar` is provided, the same Sidebar gets rendered inside
              the drawer body so the user's folder tree is reachable on mobile
              without any new JS. CSS (layout.css) hides this copy on lg+. */}
          <details class="mobile-menu">
            <summary aria-label="메뉴">
              {/* Hamburger + close X overlap. CSS swaps which is visible via
                  the [open] selector — fade + rotate ~90° between the two. */}
              <svg class="mobile-menu__icon mobile-menu__icon--bars" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 6h18M3 12h18M3 18h18" />
              </svg>
              <svg class="mobile-menu__icon mobile-menu__icon--close" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 6l12 12M18 6L6 18" />
              </svg>
            </summary>
            <div class={`mobile-menu__panel${hasSidebar ? " mobile-menu__panel--with-sidebar" : ""}`}>
              <nav class="mobile-menu__nav" aria-label="모바일 메뉴">
                <ul role="list">
                  <li><a href="/">Home</a></li>
                  <li><a href="/categories/">Categories</a></li>
                </ul>
              </nav>
              {hasSidebar && (
                <div class="mobile-menu__sidebar-slot">
                  <Sidebar {...sidebar!} />
                </div>
              )}
            </div>
          </details>
        </div>
      </div>
    </header>
    <div class={shellClasses}>
      {hasSidebar && (
        <div class="site-shell__sidebar">
          <Sidebar {...sidebar!} />
        </div>
      )}
      <main id="main" class="site-main">
        <slot />
      </main>
      {hasToc && (
        <div class="site-shell__toc">
          <TableOfContents {...tableOfContents!} />
        </div>
      )}
    </div>
    <footer class="site-footer">
      <div class="site-footer__inner">
        <span>© 2026 — {siteName}</span>
        <a href="https://github.com/lim010111/noteforge" target="_blank" rel="noopener noreferrer">source</a>
        <a href="https://github.com/lim010111/noteforge/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">MIT</a>
      </div>
    </footer>
    {/* Theme toggle handler — bundled module, not inline. The resolve+set
        logic lives in `theme-init.ts` so it stays single-source-of-truth with
        the FOUC-prevention `themeInitScript` block above; this script just
        binds it to the button. */}
    <script>
      import { bindThemeToggle } from "../scripts/theme-init.ts";
      const btn = document.getElementById("theme-toggle");
      if (btn !== null) {
        bindThemeToggle(
          btn,
          document.documentElement,
          window.localStorage,
          window.matchMedia("(prefers-color-scheme: dark)"),
        );
      }
    </script>
    {/* Sticky-header shadow — toggles `is-scrolled` on <body> when the 1px
        sentinel above the header has scrolled out of view. Progressive
        enhancement only: without IntersectionObserver the header simply
        keeps its hairline border-bottom, which is the v0.2 baseline. */}
    <script>
      (() => {
        if (!("IntersectionObserver" in window)) return;
        const sentinel = document.querySelector(".site-header__sentinel");
        if (sentinel === null) return;
        const observer = new IntersectionObserver(
          (entries) => {
            const e = entries[0];
            if (e === undefined) return;
            document.body.classList.toggle("is-scrolled", !e.isIntersecting);
          },
          { threshold: 0 },
        );
        observer.observe(sentinel);
      })();
    </script>
  </body>
</html>
