---
/**
 * Per-tag listing page — view-only.
 *
 * Privacy contract: `tag` is already blocklist-filtered, and `entries[].slug`
 * is guaranteed PUBLIC by the caller (built from `PipelineResult.publicSlugs`).
 *
 * Empty state for `entries`: render `<h1>` with the tag and an explicit
 * "이 태그를 가진 공개 노트가 없습니다" message. Unlike Backlinks/TagList,
 * this page IS routed by the user (they typed `/tags/<tag>`), so the page's
 * existence is already known. We MUST NOT redirect or 404 (that would imply
 * the tag exists privately). Showing an empty list is fine.
 *
 * Listing visuals (the `<ul>`/`<li>`/`<time>`/`<a>` shape) are delegated to
 * `<NoteList />` so the home page renders identical row visuals without
 * borrowing TagPage-named classes.
 */
import type { TagPageProps } from "./TagPage.types";
import NoteList from "./NoteList.astro";
import type { NoteListEntry } from "./NoteList.types";
const { tagpage } = Astro.props as TagPageProps;
const items: NoteListEntry[] = tagpage.entries.map((e) => {
  const item: NoteListEntry = { href: `/${e.slug}`, title: e.title };
  if (e.description !== undefined) item.description = e.description;
  if (e.tags !== undefined) item.tags = e.tags;
  if (e.date !== undefined) item.date = e.date;
  if (e.thumbnail !== undefined) item.thumbnail = e.thumbnail;
  return item;
});
---
<section class="tag-page">
  <h1 class="tag-page__heading">#{tagpage.tag}</h1>
  <NoteList entries={items} emptyMessage="이 태그를 가진 공개 노트가 없습니다." />
</section>
