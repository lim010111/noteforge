---
/**
 * FolderTree — JS-less folder hierarchy.
 *
 * Markup contract:
 *   - Outer wrapper: `<nav aria-label="Folder tree">`. **No `role="tree"`** —
 *     the standard tree role mandates arrow-key handlers we deliberately do
 *     not ship (static-only, JS bundle 0). Tab + Enter/Space on <summary> is
 *     the entire keyboard contract.
 *   - Each folder: `<li><details><summary>chevron + <a>name</a></summary><ul>kids</ul></details></li>`
 *     — the folder-name link lives **inside** <summary> so it stays visible
 *     when the folder is collapsed (browsers hide non-summary children of a
 *     closed <details>). On a plain left-click the page navigates away, so the
 *     bubble-up <details> toggle has no observable effect. On Cmd/Ctrl-click,
 *     middle-click, or right-click → open-in-new-tab the current tab does not
 *     navigate, so the <details> *will* toggle in place; this is recoverable
 *     because `open={open}` is derived from `currentSlug` and the next page
 *     load (or a refresh) restores the canonical open-state. JS-less by design,
 *     so we accept that small flicker over a one-line `event.stopPropagation`.
 *     Clicking the chevron / empty summary area toggles open state directly.
 *   - Each note: `<li class="...--leaf"><a href="/<slug>/">title</a></li>`
 *     (trailing slash per ADR-012).
 *   - Empty root (`children`+`notes` both 0) → component renders nothing
 *     (no <nav>, no aria-label). Empty section labels are themselves a leak
 *     signal ("there used to be folders here").
 *
 * Active state:
 *   - `activeSlug` (e.g. 'AI/Claude/agents') marks a note link with
 *     `aria-current="page"` and auto-opens every ancestor <details>.
 *   - `activeFolderPath` (e.g. 'AI/Claude/' — trailing slash tolerated) marks
 *     the matching folder NAME link with `aria-current="page"` and auto-opens
 *     the chain to it. The folder index page is the "current" location, not
 *     any contained note.
 *
 * Recursion: this component invokes `<Astro.self />` on each folder. The
 * presence of `branch`/`depth` props discriminates root mode (renders
 * <nav>+<ul>) from branch mode (renders <ul> only, no <nav>).
 *
 * Privacy contract: input is already filtered upstream (apps/blog's sidebar
 * payload feeds in `filterPublishable` output). The component renders or
 * omits — it never re-derives privacy state.
 */
import type { FolderTreeProps } from "./FolderTree.types";
import type { FolderNode } from "../lib/folderTree.types";

type Props = FolderTreeProps & {
  /** Internal recursion: present on sub-invocations of <Astro.self />. */
  branch?: FolderNode;
  /** Internal recursion: depth of the children being rendered (root call = 0). */
  depth?: number;
  /** Internal recursion: pre-normalised active folder path (trailing slash stripped). */
  normalizedActiveFolder?: string;
};

function shouldRenderAsLeafLink(child: FolderNode, hideLeafNotes: boolean): boolean {
  // A category whose children list is empty AND whose own notes are being
  // hidden produces a `<details>` with nothing inside — visual noise. In
  // that case we render the row as a single link instead so the sidebar
  // stays compact and the user can still navigate to the category index.
  return hideLeafNotes && child.children.length === 0 && child.notes.length === 0;
}

const props = Astro.props as Props;
const isBranch = props.branch !== undefined;
const node: FolderNode = isBranch ? (props.branch as FolderNode) : props.root;
const activeSlug = props.activeSlug;
const hideLeafNotes = props.hideLeafNotes ?? false;
// `slotCount` is preserved on the props contract for API stability across
// theme consumers, but the v0.5 design refresh dropped the per-folder colour
// dot; the prop is intentionally unused here. See CategoryOverview/FolderIndex
// for the surfaces that still consume it.
const slotCount = props.slotCount;
void slotCount;

const normalizedActiveFolder = isBranch
  ? props.normalizedActiveFolder
  : props.activeFolderPath !== undefined
    ? props.activeFolderPath.replace(/\/+$/, "")
    : undefined;

// When leaf notes are hidden, an otherwise-empty tree (no children, only
// notes) collapses to "nothing visible" — the component renders nothing,
// matching the no-folders-no-notes case so the heading is never an
// existence oracle for an empty section.
const isEmpty =
  node.children.length === 0 &&
  (hideLeafNotes || node.notes.length === 0);

function isFolderOpen(folderPath: string): boolean {
  const prefix = folderPath + "/";
  if (
    activeSlug !== undefined &&
    (activeSlug === folderPath || activeSlug.startsWith(prefix))
  )
    return true;
  if (
    normalizedActiveFolder !== undefined &&
    (normalizedActiveFolder === folderPath ||
      normalizedActiveFolder.startsWith(prefix))
  )
    return true;
  return false;
}

function isFolderActive(folderPath: string): boolean {
  return normalizedActiveFolder === folderPath;
}

function isNoteActive(slug: string): boolean {
  return activeSlug === slug;
}
---
{!isBranch && !isEmpty && (
  <nav class="folder-tree" aria-label="Folder tree">
    <h2 class="folder-tree__heading">Categories</h2>
    <ul class="folder-tree__list">
      {node.children.map((child) => {
        const open = isFolderOpen(child.path);
        const active = isFolderActive(child.path);
        if (shouldRenderAsLeafLink(child, hideLeafNotes)) {
          return (
            <li class="folder-tree__item folder-tree__item--leaf-category">
              <a
                class={`folder-tree__name${active ? " folder-tree__name--active" : ""}`}
                href={`/${child.path}/`}
                aria-current={active ? "page" : undefined}
              >
                {child.name}
              </a>
            </li>
          );
        }
        return (
          <li class="folder-tree__item">
            <details class="folder-tree__details" open={open}>
              <summary class="folder-tree__summary">
                <span class="folder-tree__chevron" aria-hidden="true">▸</span>
                <a
                  class={`folder-tree__name${active ? " folder-tree__name--active" : ""}`}
                  href={`/${child.path}/`}
                  aria-current={active ? "page" : undefined}
                >
                  {child.name}
                </a>
              </summary>
              <Astro.self
                root={props.root}
                slotCount={slotCount}
                activeSlug={activeSlug}
                hideLeafNotes={hideLeafNotes}
                branch={child}
                depth={1}
                normalizedActiveFolder={normalizedActiveFolder}
              />
            </details>
          </li>
        );
      })}
      {!hideLeafNotes && node.notes.map((n) => {
        const active = isNoteActive(n.slug);
        return (
          <li class="folder-tree__item folder-tree__item--leaf">
            <a
              class={`folder-tree__note-link${active ? " folder-tree__note-link--active" : ""}`}
              href={`/${n.slug}/`}
              aria-current={active ? "page" : undefined}
            >
              {n.title}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
)}
{isBranch && !isEmpty && (
  <ul class="folder-tree__children">
    {node.children.map((child) => {
      const open = isFolderOpen(child.path);
      const active = isFolderActive(child.path);
      if (shouldRenderAsLeafLink(child, hideLeafNotes)) {
        return (
          <li class="folder-tree__item folder-tree__item--leaf-category">
            <a
              class={`folder-tree__name${active ? " folder-tree__name--active" : ""}`}
              href={`/${child.path}/`}
              aria-current={active ? "page" : undefined}
            >
              {child.name}
            </a>
          </li>
        );
      }
      return (
        <li class="folder-tree__item">
          <details class="folder-tree__details" open={open}>
            <summary class="folder-tree__summary">
              <span class="folder-tree__chevron" aria-hidden="true">▸</span>
              <a
                class={`folder-tree__name${active ? " folder-tree__name--active" : ""}`}
                href={`/${child.path}/`}
                aria-current={active ? "page" : undefined}
              >
                {child.name}
              </a>
            </summary>
            <Astro.self
              root={props.root}
              slotCount={slotCount}
              activeSlug={activeSlug}
              hideLeafNotes={hideLeafNotes}
              branch={child}
              depth={(props.depth as number) + 1}
              normalizedActiveFolder={normalizedActiveFolder}
            />
          </details>
        </li>
      );
    })}
    {!hideLeafNotes && node.notes.map((n) => {
      const active = isNoteActive(n.slug);
      return (
        <li class="folder-tree__item folder-tree__item--leaf">
          <a
            class={`folder-tree__note-link${active ? " folder-tree__note-link--active" : ""}`}
            href={`/${n.slug}/`}
            aria-current={active ? "page" : undefined}
          >
            {n.title}
          </a>
        </li>
      );
    })}
  </ul>
)}
