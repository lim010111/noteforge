---
/**
 * Single-note body component.
 *
 * View-only: the privacy pipeline (`@noteforge/core/privacy`) has already decided
 * what is allowed to appear here. This component MUST NOT re-derive isPublic,
 * re-run link rewriting, re-strip comments, or read fields outside NoteViewModel.
 *
 * `set:html` is permitted on `note.body` ONLY. `body` is the single
 * sanitized-HTML field in the contract; piping any other value through `set:html`
 * would open a raw-injection / stored-XSS path.
 *
 * Visual contract: prose styling lives in `theme-default/src/styles/prose.css`
 * (imported transitively via base.css). The component owns layout (article root
 * width, header meta row); typography lives in CSS so vault-rendered HTML inside
 * `set:html` picks up the same rules as native Astro children.
 */
import type { NoteProps } from "./Note.types";

const { note } = Astro.props as NoteProps;
---
<article class="prose w-full mx-auto max-w-[var(--measure-prose)]">
  <header
    class={`note-header not-prose${note.heroImage ? " note-header--with-hero" : ""}`}
  >
    {note.heroImage && (
      <div
        class="note-header__hero"
        aria-hidden="true"
        style={`background-image: url('${note.heroImage}')`}
      />
    )}
    <h1>{note.title}</h1>
    {(note.date || note.updated || note.tags.length > 0) && (
      <div class="note-meta">
        {note.date && <time datetime={note.date}>{note.date}</time>}
        {note.updated && <span>updated {note.updated}</span>}
        {note.tags.map((t) => (
          <a href={`/tags/${encodeURIComponent(t)}`}>#{t}</a>
        ))}
      </div>
    )}
  </header>
  <div set:html={note.body} />
</article>
