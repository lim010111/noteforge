---
/**
 * Categories overview — shown at `/categories/`.
 *
 * Each section is a top-level vault folder; its `notes[]` is the flattened
 * descendants list, pre-sorted by the caller (date desc → href asc, mirroring
 * `entriesForTag`).
 *
 * The v0.5 design refresh removed the per-folder colour dot — the editorial
 * masthead + section opener layout now carries the visual identity instead.
 * `slotCount` stays on the props contract for API stability and parity with
 * surfaces that still use the accent (FolderIndex breadcrumb).
 *
 * Privacy contract: this component renders verbatim. The caller has already
 * passed `filterPublishable` output through `buildFolderTree` and
 * `buildCategoryOverviewSections`; nothing here re-derives privacy.
 *
 * Empty bucket handling: a section with `notes.length === 0` would mean a
 * folder shaped purely by sub-folders that themselves are all empty — in
 * practice this cannot happen because `buildFolderTree` only creates folder
 * nodes when a publishable note lives inside. We still render a concise
 * "비어 있음" line for symmetry with the rest of the UI.
 */
import type { CategoryOverviewProps } from "./CategoryOverview.types";

const { sections, emptyMessage, slotCount } =
  Astro.props as CategoryOverviewProps;
void slotCount;
---
{sections.length === 0 ? (
  <p class="category-overview__empty">{emptyMessage}</p>
) : (
  <div class="category-overview">
    <div class="category-overview__sections">
      {sections.map((section, idx) => {
        const count = section.notes.length;
        return (
          <section
            class="category-overview__section"
            aria-labelledby={`cat-${idx}`}
          >
            <div class="category-overview__section-head">
              <h2 id={`cat-${idx}`} class="category-overview__name">
                {section.href !== undefined ? (
                  <a class="category-overview__name-link" href={section.href}>
                    {section.name}
                  </a>
                ) : (
                  section.name
                )}
              </h2>
              <span class="category-overview__count">
                {count}{" "}
                <span class="category-overview__count-label">
                  {count === 1 ? 'note' : 'notes'}
                </span>
              </span>
            </div>
            {count === 0 ? (
              <p class="category-overview__section-empty">비어 있음</p>
            ) : (
              <ul class="category-overview__list" role="list">
                {section.notes.map((note) => (
                  <li class="category-overview__item">
                    <a class="post-preview category-overview__row" href={note.href}>
                      {note.thumbnail ? (
                        <img
                          class="post-preview__thumb category-overview__thumb not-prose"
                          src={note.thumbnail}
                          alt=""
                          loading="lazy"
                          decoding="async"
                        />
                      ) : (
                        <span
                          class="post-preview__thumb category-overview__thumb category-overview__thumb--placeholder not-prose"
                          aria-hidden="true"
                        >
                          ▢
                        </span>
                      )}
                      <span class="post-preview__content category-overview__row-content">
                        <span class="post-preview__title category-overview__row-title">{note.title}</span>
                        {note.description !== undefined && (
                          <span class="post-preview__description">{note.description}</span>
                        )}
                        {((note.tags?.length ?? 0) > 0 || note.date !== undefined) && (
                          <span class="post-preview__meta">
                            {(note.tags?.length ?? 0) > 0 && (
                              <span class="post-preview__tags">
                                {note.tags!.map((tag) => `#${tag}`).join(' ')}
                              </span>
                            )}
                            {(note.tags?.length ?? 0) > 0 && note.date !== undefined && (
                              <span class="post-preview__sep" aria-hidden="true">|</span>
                            )}
                            {note.date !== undefined && (
                              <time
                                datetime={note.date}
                                class="post-preview__date category-overview__date"
                              >
                                {note.date}
                              </time>
                            )}
                          </span>
                        )}
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </section>
        );
      })}
    </div>
  </div>
)}
