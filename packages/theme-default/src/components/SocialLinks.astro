---
/**
 * SocialLinks — opt-in contact channels rendered inside `.header-actions`.
 *
 * Three-state contract per channel:
 *   - prop omitted    → channel hidden (no DOM remnant; full opt-out, the
 *     existing privacy contract for bloggers who never set `site.social`).
 *   - empty string '' → "needs setup" stub icon. Rendered as a `<button>`
 *     (not an `<a>`, since there is no destination yet). Clicking it opens
 *     a small native alert telling the user which config field to edit.
 *     This powers the first-run UX in the default
 *     `apps/blog/noteforge.config.ts`, so fork users can *discover* the
 *     icon before they have configured it.
 *   - non-empty URL   → live outbound anchor (the original behavior).
 *
 * When every channel is omitted the component returns nothing — no <span>,
 * no whitespace, no DOM remnant.
 *
 * Markup contract:
 *   - Wrapper: `<span class="social-links" role="list">` only when at
 *     least one channel will render (omitted OR stub OR live).
 *   - Each item is a `<span role="listitem">` whose only child is an
 *     `<a class="icon-button">` or `<button class="icon-button">`. ARIA
 *     `role="listitem"` cannot live on the interactive element directly —
 *     an explicit role overrides the element's implicit role, so a screen
 *     reader would announce the link/button as a listitem instead of its
 *     real role. Wrapping keeps both semantics intact.
 *   - The `.icon-button` class (layout.css) supplies size + hover swap, so
 *     this component owns no per-link visuals.
 *   - Live GitHub link is outbound — `target="_blank" rel="noopener noreferrer"`
 *     matches the footer convention. The mailto link needs neither.
 *   - Korean `aria-label`s match the existing convention.
 *
 * Icons are inline SVG with `currentColor` (fill for GitHub mark, stroke
 * for the envelope) so the existing `.icon-button` color cascade keeps
 * working without a new sprite system or an `astro-icon` dependency.
 */
import type { SocialLinksProps } from "./SocialLinks.types";

const { github, email } = Astro.props as SocialLinksProps;
const githubState: "off" | "stub" | "live" =
  typeof github !== "string"
    ? "off"
    : github.length === 0
      ? "stub"
      : "live";
const showGithub = githubState !== "off";
const showEmail = typeof email === "string" && email.length > 0;
const renderAny = showGithub || showEmail;
---
{renderAny && (
  <span class="social-links" role="list">
    {showGithub && githubState === "live" && (
      <span role="listitem">
        <a
          class="icon-button"
          href={github}
          aria-label="GitHub"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2.02c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.69-1.28-1.69-1.05-.71.08-.7.08-.7 1.16.08 1.78 1.2 1.78 1.2 1.03 1.77 2.7 1.26 3.36.97.1-.75.4-1.26.74-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.74.8 1.18 1.83 1.18 3.09 0 4.42-2.69 5.39-5.26 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.55A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
          </svg>
        </a>
      </span>
    )}
    {showGithub && githubState === "stub" && (
      <span role="listitem">
        <button
          type="button"
          class="icon-button"
          aria-label="GitHub (설정 필요)"
          title="본인의 GitHub URL을 noteforge.config.ts → site.social.github 에 입력해주세요"
          data-social-stub="github"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2.02c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.69-1.28-1.69-1.05-.71.08-.7.08-.7 1.16.08 1.78 1.2 1.78 1.2 1.03 1.77 2.7 1.26 3.36.97.1-.75.4-1.26.74-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.74.8 1.18 1.83 1.18 3.09 0 4.42-2.69 5.39-5.26 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.55A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
          </svg>
        </button>
      </span>
    )}
    {showEmail && (
      <span role="listitem">
        <a
          class="icon-button"
          href={`mailto:${email}`}
          aria-label="이메일"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path d="m3 7 9 6 9-6" />
          </svg>
        </a>
      </span>
    )}
  </span>
)}

{/* The stub button only ships when a config explicitly opts in with
    `github: ''` — the inline script then nudges the fork user toward the
    config field. We rely on a tiny module script instead of an inline
    `onclick` so the markup stays CSP-friendly even if a future release
    enables strict CSP (see docs/DEPLOY.md §8). The script is idempotent:
    no-op on pages where no stub button rendered. */}
<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(
    'button[data-social-stub="github"]',
  );
  for (const btn of buttons) {
    btn.addEventListener("click", () => {
      window.alert(
        "본인의 GitHub URL을 입력해주세요.\n\napps/blog/noteforge.config.ts → site.social.github 필드에 'https://github.com/<your-username>' 형식으로 채워주세요.",
      );
    });
  }
</script>
