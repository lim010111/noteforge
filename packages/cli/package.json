{
  "name": "@noteforge/cli",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "CLI (obpub dev/build/audit/status) for noteforge.",
  "type": "module",
  "bin": {
    "obpub": "./dist/bin.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=22.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PLACEHOLDER_OWNER/PLACEHOLDER_REPO.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/PLACEHOLDER_OWNER/PLACEHOLDER_REPO#readme",
  "bugs": {
    "url": "https://github.com/PLACEHOLDER_OWNER/PLACEHOLDER_REPO/issues"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "obpub": "node ./dist/bin.js",
    "obpub:dev": "node --experimental-strip-types ./src/bin.ts",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@noteforge/core": "workspace:*",
    "tsup": "^8.3.0",
    "vitest": "^3.2.0"
  }
}
