---
import { getCollection } from 'astro:content';
import { BaseLayout, NoteList, type NoteListEntry } from '@noteforge/theme-default';
import obpubConfig from '../../obsidian-blog.config.ts';
import { filterPublishable, sortForHome } from '../lib/viewModels.ts';
import '../styles/global.css';

const all = await getCollection('notes');
const sorted = sortForHome(filterPublishable(all));
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const items: NoteListEntry[] = sorted.map((entry) => {
  const dateRaw = entry.data.frontmatter['date'];
  const item: NoteListEntry = {
    href: `/${entry.id}`,
    title: entry.data.title ?? entry.id,
  };
  if (typeof dateRaw === 'string') item.date = dateRaw;
  return item;
});
---
<BaseLayout title="홈" canonicalUrl={canonicalUrl} ogType="website" siteName={obpubConfig.site.title}>
  <NoteList entries={items} emptyMessage="아직 공개된 글이 없습니다." />
</BaseLayout>
