---
import { getCollection } from 'astro:content';
import { BaseLayout } from '@noteforge/theme-default';
import obpubConfig from '../../obsidian-blog.config.ts';
import {
  coerceDate,
  ensureTrailingSlash,
  filterPublishable,
  slugBasename,
  type NoteEntry,
} from '../lib/viewModels.ts';
import { selectFeatured, selectRecent } from '../lib/homeRails.ts';
import { buildSidebarPayload } from '../lib/sidebarPayload.ts';
import '../styles/global.css';

const all = await getCollection('notes');
const publishable = filterPublishable(all);
const recent = selectRecent(publishable);
const featured = selectFeatured(publishable);
const sidebar = buildSidebarPayload(all);

interface HomeRailItem {
  href: string;
  title: string;
  date?: string;
}

function toItems(entries: readonly NoteEntry[]): HomeRailItem[] {
  return entries.map((entry) => {
    const date = coerceDate(entry.data.frontmatter['date']);
    const item: HomeRailItem = {
      href: `/${entry.id}/`,
      // v0.5 — when a note has no frontmatter title, surface the slug's last
      // segment ("lora") rather than its full path ("ai/gen-ai/공부-일지/lora").
      // The latter was the user-visible "/" rail that read as URL noise.
      title: entry.data.title ?? slugBasename(entry.id),
    };
    if (date !== undefined) item.date = date;
    return item;
  });
}

const recentItems = toItems(recent);
const featuredItems = toItems(featured);
const canonicalUrl = ensureTrailingSlash(
  new URL(Astro.url.pathname, Astro.site).toString(),
);

function pad2(n: number): string {
  return n < 10 ? `0${n}` : String(n);
}

interface HomeSection {
  id: string;
  name: string;
  items: HomeRailItem[];
}

const sections: HomeSection[] = [
  { id: 'recent', name: 'Recent', items: recentItems },
];
if (featuredItems.length > 0) {
  sections.push({ id: 'featured', name: 'Featured', items: featuredItems });
}
---
<BaseLayout
  title="홈"
  canonicalUrl={canonicalUrl}
  ogType="website"
  siteName={obpubConfig.site.title}
  sidebar={sidebar}
  social={obpubConfig.site.social}
>
  {/*
    v0.5 — the home page reuses the editorial-technical section opener
    visuals from CategoryOverview so /, /categories/, and /tags/<t>/ feel
    like one document family. Class names retain the `category-overview__*`
    namespace because that is where the styling SSOT lives — duplicating
    them under a new prefix would split the CSS rules across two grep
    targets and invite drift.
  */}
  <div class="category-overview">
    {sections.length === 0 ? (
      <p class="category-overview__empty">아직 공개된 글이 없습니다.</p>
    ) : (
      <div class="category-overview__sections">
        {sections.map((section, idx) => {
          const count = section.items.length;
          return (
            <section
              class="category-overview__section"
              aria-labelledby={`home-${section.id}`}
            >
              <div class="category-overview__section-head">
                <span class="category-overview__index" aria-hidden="true">
                  {pad2(idx + 1)}
                </span>
                <h2
                  id={`home-${section.id}`}
                  class="category-overview__name"
                >
                  {section.name}
                </h2>
                <span class="category-overview__count">
                  {count}{' '}
                  <span class="category-overview__count-label">
                    {count === 1 ? 'note' : 'notes'}
                  </span>
                </span>
              </div>
              {count === 0 ? (
                <p class="category-overview__section-empty">비어 있음</p>
              ) : (
                <ul class="category-overview__list" role="list">
                  {section.items.map((item) => (
                    <li class="category-overview__item">
                      <a class="category-overview__row" href={item.href}>
                        {item.date !== undefined ? (
                          <time
                            datetime={item.date}
                            class="category-overview__date"
                          >
                            {item.date}
                          </time>
                        ) : (
                          <span
                            class="category-overview__date category-overview__date--missing"
                            aria-hidden="true"
                          >
                            ——
                          </span>
                        )}
                        <span class="category-overview__row-title">
                          {item.title}
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </section>
          );
        })}
      </div>
    )}
  </div>
</BaseLayout>
