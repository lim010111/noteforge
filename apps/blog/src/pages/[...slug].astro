---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import {
  Backlinks,
  BaseLayout,
  FolderIndex,
  Note,
  type FolderIndexViewModel,
} from '@noteforge/theme-default';
import obpubConfig from '../../noteforge.config.ts';
import {
  buildBacklinksViewModel,
  displayTitleForEntry,
  ensureTrailingSlash,
  entryToAliasRedirectViewModel,
  entryToNoteViewModel,
  filterPublishable,
  type AliasRedirectEntry,
  type NoteEntry,
} from '../lib/viewModels.ts';
import {
  buildCategoryIndexViewModel,
  buildCategoryTree,
  buildFolderIndexViewModel,
  buildFolderTree,
  walkCategories,
  walkFolders,
} from '../lib/folderAggregation.ts';
import {
  assertNoAliasCollisions,
  assertNoCategoryCollisions,
  assertNoFolderCollisions,
} from '../lib/routeCollisions.ts';
import { buildSidebarPayload, type SidebarPayload } from '../lib/sidebarPayload.ts';
import '../styles/global.css';

export const getStaticPaths: GetStaticPaths = async () => {
  const all = await getCollection('notes');
  const publishable = filterPublishable(all);
  const titleBySlug = new Map(
    publishable.map((e) => [e.id, displayTitleForEntry(e)] as const),
  );

  const noteRoutes = publishable.map((entry) => ({
    params: { slug: entry.id },
    props: { kind: 'note' as const, entry, titleBySlug },
  }));

  const aliasEntries = all.filter(
    (e): e is AliasRedirectEntry => e.data.kind === 'alias-redirect',
  );

  // Defense-in-depth: the loader already throws on alias↔note id collisions
  // (step 1) and `buildAliasRedirects` filters its own duplicates (step 0).
  // Re-checking here turns any future regression that lets two routes claim
  // the same slug into a build-time failure with a precise message rather
  // than Astro's generic duplicate-route error. Folder-index routes (v0.3)
  // share the same `claimed` set so a `posts/` folder colliding with a
  // `posts` note or `posts` alias fails build-time with a parallel message.
  const noteSlugs = new Set(noteRoutes.map((r) => r.params.slug));
  assertNoAliasCollisions(
    noteSlugs,
    aliasEntries.map((a) => ({ slug: a.id, to: a.data.to })),
  );
  const claimed = new Set(noteSlugs);
  for (const alias of aliasEntries) claimed.add(alias.id);

  const aliasRoutes = aliasEntries.map((entry) => ({
    params: { slug: entry.id },
    props: {
      kind: 'alias-redirect' as const,
      entry,
      to: ensureTrailingSlash(`/${entry.data.to}`),
    },
  }));

  // Folder-index routes (v0.3) and category-index routes (v0.7 follow-up).
  // The trees are built from the same `publishable` set the note routes use —
  // privacy filtering happens once upstream, never re-derived here. Root
  // (path '') is excluded; that URL is owned by `apps/blog/src/pages/index.astro`.
  //
  // `nav.mode === 'folder'` emits folder-index routes keyed by vault path.
  // `nav.mode === 'category'` emits category-index routes keyed by the
  // slugified `category` frontmatter field. The two modes are mutually
  // exclusive; the sidebar (FolderTree) and overview page mirror the same
  // selection so links and routes stay in lockstep.
  const folderRoutes: Array<{
    params: { slug: string };
    props: { kind: 'folder-index'; viewModel: FolderIndexViewModel };
  }> = [];
  const categoryRoutes: Array<{
    params: { slug: string };
    props: { kind: 'category-index'; viewModel: FolderIndexViewModel };
  }> = [];
  if (obpubConfig.nav.mode === 'folder') {
    const tree = buildFolderTree(publishable);
    for (const folder of walkFolders(tree)) {
      const viewModel = buildFolderIndexViewModel(tree, folder.path);
      if (viewModel === null) continue;
      folderRoutes.push({
        params: { slug: folder.path },
        props: { kind: 'folder-index', viewModel },
      });
    }
  } else {
    const tree = buildCategoryTree(publishable);
    for (const cat of walkCategories(tree)) {
      const viewModel = buildCategoryIndexViewModel(tree, cat.path);
      if (viewModel === null) continue;
      categoryRoutes.push({
        params: { slug: cat.path },
        props: { kind: 'category-index', viewModel },
      });
    }
  }

  assertNoFolderCollisions(
    claimed,
    folderRoutes.map((f) => ({ slug: f.params.slug })),
  );
  assertNoCategoryCollisions(
    claimed,
    categoryRoutes.map((c) => ({ slug: c.params.slug })),
  );

  return [...noteRoutes, ...aliasRoutes, ...folderRoutes, ...categoryRoutes];
};

type Props =
  | {
      kind: 'note';
      entry: NoteEntry;
      titleBySlug: ReadonlyMap<string, string>;
    }
  | {
      kind: 'alias-redirect';
      entry: AliasRedirectEntry;
      to: string;
    }
  | {
      kind: 'folder-index';
      viewModel: FolderIndexViewModel;
    }
  | {
      kind: 'category-index';
      viewModel: FolderIndexViewModel;
    };

const props = Astro.props as Props;

// Single invariant for all branches: canonical URLs require an origin, and
// `noteforge.config.ts` mandates `site.url`. Surfacing the missing-config
// case here as a build-time throw beats either silently falling back (alias
// branch's old behaviour) or throwing deeper inside `new URL()` with a less
// actionable message (note branch's old behaviour).
if (Astro.site === undefined) {
  throw new Error(
    "[...slug].astro: Astro.site is required for canonical URLs and alias redirects. " +
      "Set obpubConfig.site.url in noteforge.config.ts.",
  );
}
const siteOrigin = Astro.site;

let renderedNote: ReturnType<typeof entryToNoteViewModel> | null = null;
let backlinks: ReturnType<typeof buildBacklinksViewModel> | null = null;
let noteCanonical: string | undefined;

let aliasTo: string | null = null;
let aliasCanonical: string | undefined;

let folderCanonical: string | undefined;
let folderTitle: string | undefined;

let sidebar: SidebarPayload | undefined;

if (props.kind === 'note') {
  const html = props.entry.rendered?.html ?? '';
  renderedNote = entryToNoteViewModel(props.entry, html);
  backlinks = buildBacklinksViewModel(props.entry, props.titleBySlug);
  noteCanonical = ensureTrailingSlash(
    new URL(Astro.url.pathname, siteOrigin).toString(),
  );
  const all = await getCollection('notes');
  sidebar = buildSidebarPayload(
    all,
    { activeSlug: props.entry.id },
    obpubConfig.nav,
  );
} else if (props.kind === 'alias-redirect') {
  const absoluteTo = new URL(props.to, siteOrigin).toString();
  const vm = entryToAliasRedirectViewModel(props.entry, absoluteTo);
  aliasTo = vm.to;
  aliasCanonical = vm.canonicalUrl;
  // alias-redirect intentionally renders without a sidebar — the page is a
  // 0-second meta-refresh, so painting the folder tree (with note slugs) for
  // the fraction of a second before navigation is a needless leak surface.
} else {
  // Both 'folder-index' and 'category-index' use the same renderer
  // (`<FolderIndex />`) and view-model shape; the discriminator only drives
  // sidebar mode propagation here.
  folderCanonical = ensureTrailingSlash(
    new URL(Astro.url.pathname, siteOrigin).toString(),
  );
  folderTitle = props.viewModel.folderName;
  const all = await getCollection('notes');
  sidebar = buildSidebarPayload(
    all,
    { activeFolderPath: `${props.viewModel.folderPath}/` },
    obpubConfig.nav,
  );
}
---
{props.kind === 'alias-redirect' ? (
  <BaseLayout
    title="이 페이지는 이동되었습니다"
    canonicalUrl={aliasCanonical}
    ogType="website"
    siteName={obpubConfig.site.title}
  >
    <Fragment slot="head">
      <meta http-equiv="refresh" content={`0; url=${ensureTrailingSlash(aliasTo!)}`} />
    </Fragment>
    <p>이 페이지는 <a href={aliasTo}>여기</a>로 이동되었습니다.</p>
  </BaseLayout>
) : props.kind === 'folder-index' || props.kind === 'category-index' ? (
  <BaseLayout
    title={folderTitle!}
    canonicalUrl={folderCanonical}
    ogType="website"
    siteName={obpubConfig.site.title}
    sidebar={sidebar}
  >
    <FolderIndex view={props.viewModel} />
  </BaseLayout>
) : (
  <BaseLayout
    title={renderedNote!.title}
    description={renderedNote!.description}
    canonicalUrl={noteCanonical}
    ogType="article"
    siteName={obpubConfig.site.title}
    sidebar={sidebar}
    tableOfContents={
      renderedNote!.headings && renderedNote!.headings.length > 0
        ? { headings: renderedNote!.headings }
        : undefined
    }
  >
    <Note note={renderedNote!} />
    <Backlinks backlinks={backlinks!} />
  </BaseLayout>
)}
