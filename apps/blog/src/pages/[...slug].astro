---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import { Backlinks, BaseLayout, Note } from '@obpub/theme-default';
import {
  buildBacklinksViewModel,
  entryToNoteViewModel,
  filterPublishable,
  type NotesEntry,
} from '../lib/viewModels.ts';
import '../styles/global.css';

export const getStaticPaths: GetStaticPaths = async () => {
  const all = await getCollection('notes');
  const publishable = filterPublishable(all);
  const titleBySlug = new Map(
    publishable.map((e) => [e.id, e.data.title ?? e.id] as const),
  );
  return publishable.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, titleBySlug },
  }));
};

interface Props {
  entry: NotesEntry;
  titleBySlug: ReadonlyMap<string, string>;
}

const { entry, titleBySlug } = Astro.props as Props;
const html = entry.rendered?.html ?? '';
const note = entryToNoteViewModel(entry, html);
const backlinks = buildBacklinksViewModel(entry, titleBySlug);
---
<BaseLayout title={note.title} description={note.description}>
  <Fragment slot="nav">
    <ul class="flex gap-4 py-4 text-sm">
      <li><a href="/" class="text-zinc-500 hover:text-zinc-900">홈</a></li>
      <li><a href="/graph" class="text-zinc-500 hover:text-zinc-900">그래프</a></li>
      <li><a href="/tags" class="text-zinc-500 hover:text-zinc-900">태그</a></li>
    </ul>
  </Fragment>
  <Note note={note} />
  <Backlinks backlinks={backlinks} />
</BaseLayout>
