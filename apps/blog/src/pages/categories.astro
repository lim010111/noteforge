---
import { getCollection } from 'astro:content';
import {
  BaseLayout,
  CategoryOverview,
  CATEGORY_ACCENT_SLOT_COUNT,
  type CategoryOverviewSection,
} from '@noteforge/theme-default';
import obpubConfig from '../../obsidian-blog.config.ts';
import {
  coerceDate,
  ensureTrailingSlash,
  filterPublishable,
  type NoteEntry,
} from '../lib/viewModels.ts';
import {
  buildCategoryTree,
  buildFolderTree,
} from '../lib/folderAggregation.ts';
import { buildCategoryOverviewSections } from '../lib/categoryOverviewPayload.ts';
import { buildSidebarPayload } from '../lib/sidebarPayload.ts';
import '../styles/global.css';

const navMode = obpubConfig.nav.mode;
const all = await getCollection('notes');
const publishable = filterPublishable(all);
const tree =
  navMode === 'category'
    ? buildCategoryTree(publishable)
    : buildFolderTree(publishable);

const dateBySlug = new Map<string, string>();
for (const entry of publishable as readonly NoteEntry[]) {
  const d = coerceDate(entry.data.frontmatter['date']);
  if (d !== undefined) dateBySlug.set(entry.id, d);
}

const sections: CategoryOverviewSection[] = buildCategoryOverviewSections(
  tree,
  dateBySlug,
  { sectionLinks: navMode !== 'category' },
);
const sidebar = buildSidebarPayload(all, undefined, navMode);
const canonicalUrl = ensureTrailingSlash(
  new URL(Astro.url.pathname, Astro.site).toString(),
);
---
<BaseLayout
  title="Categories"
  canonicalUrl={canonicalUrl}
  ogType="website"
  siteName={obpubConfig.site.title}
  sidebar={sidebar}
  social={obpubConfig.site.social}
>
  <CategoryOverview
    sections={sections}
    emptyMessage="아직 공개된 글이 없습니다."
    slotCount={CATEGORY_ACCENT_SLOT_COUNT}
  />
</BaseLayout>
