---
import { getCollection } from 'astro:content';
import { BaseLayout, NotFound } from '@noteforge/theme-default';
import obpubConfig from '../../noteforge.config.ts';
import { buildSidebarPayload } from '../lib/sidebarPayload.ts';
import '../styles/global.css';

const sidebar = buildSidebarPayload(
  await getCollection('notes'),
  undefined,
  obpubConfig.nav,
);
---
<BaseLayout title="찾을 수 없습니다" siteName={obpubConfig.site.title} sidebar={sidebar}>
  <NotFound />
</BaseLayout>
