---
import { getCollection } from 'astro:content';
import { BaseLayout, TagList } from '@noteforge/theme-default';
import obpubConfig from '../../../obsidian-blog.config.ts';
import { filterPublishable } from '../../lib/viewModels.ts';
import { summarizeTags } from '../../lib/tagAggregation.ts';
import '../../styles/global.css';

const publishable = filterPublishable(await getCollection('notes'));
const summaries = summarizeTags(publishable);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---
<BaseLayout title="태그" canonicalUrl={canonicalUrl} ogType="website" siteName={obpubConfig.site.title}>
  <Fragment slot="nav">
    <ul class="flex gap-4 py-4 text-sm">
      <li><a href="/" class="text-zinc-500 hover:text-zinc-900">홈</a></li>
      <li><a href="/graph" class="text-zinc-500 hover:text-zinc-900">그래프</a></li>
      <li><a href="/tags" class="text-zinc-500 hover:text-zinc-900">태그</a></li>
    </ul>
  </Fragment>
  <TagList taglist={{ tags: summaries }} />
</BaseLayout>
