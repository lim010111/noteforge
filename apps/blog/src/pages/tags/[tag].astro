---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import { BaseLayout, TagPage, type TagPageEntry } from '@noteforge/theme-default';
import obpubConfig from '../../../obsidian-blog.config.ts';
import { ensureTrailingSlash, filterPublishable } from '../../lib/viewModels.ts';
import { entriesForTag, summarizeTags } from '../../lib/tagAggregation.ts';
import { buildSidebarPayload } from '../../lib/sidebarPayload.ts';
import '../../styles/global.css';

export const getStaticPaths: GetStaticPaths = async () => {
  const publishable = filterPublishable(await getCollection('notes'));
  const summaries = summarizeTags(publishable);
  return summaries.map((s) => ({
    params: { tag: s.tag },
    props: { tag: s.tag, entries: entriesForTag(s.tag, publishable) },
  }));
};

interface Props {
  tag: string;
  entries: TagPageEntry[];
}

const { tag, entries } = Astro.props as Props;
const canonicalUrl = ensureTrailingSlash(
  new URL(Astro.url.pathname, Astro.site).toString(),
);
const sidebar = buildSidebarPayload(await getCollection('notes'));
---
<BaseLayout title={`#${tag}`} canonicalUrl={canonicalUrl} ogType="website" siteName={obpubConfig.site.title} sidebar={sidebar}>
  <TagPage tagpage={{ tag, entries }} />
</BaseLayout>
