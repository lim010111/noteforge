---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import {
  BaseLayout,
  TagPage,
  type SidebarNode,
  type TagPageEntry,
} from '@noteforge/theme-default';
import obpubConfig from '../../../obsidian-blog.config.ts';
import { filterPublishable } from '../../lib/viewModels.ts';
import { entriesForTag, summarizeTags } from '../../lib/tagAggregation.ts';
import { getSharedSidebarRoots } from '../../lib/folderTree.ts';
import '../../styles/global.css';

export const getStaticPaths: GetStaticPaths = async () => {
  const publishable = filterPublishable(await getCollection('notes'));
  const summaries = summarizeTags(publishable);
  const sidebarRoots = getSharedSidebarRoots(publishable);
  return summaries.map((s) => ({
    params: { tag: s.tag },
    props: {
      tag: s.tag,
      entries: entriesForTag(s.tag, publishable),
      sidebarRoots,
    },
  }));
};

interface Props {
  tag: string;
  entries: TagPageEntry[];
  sidebarRoots: readonly SidebarNode[];
}

const { tag, entries, sidebarRoots } = Astro.props as Props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---
<BaseLayout
  title={`#${tag}`}
  canonicalUrl={canonicalUrl}
  ogType="website"
  siteName={obpubConfig.site.title}
  sidebarRoots={sidebarRoots}
  repoUrl={obpubConfig.site.repoUrl}
>
  <TagPage tagpage={{ tag, entries }} />
</BaseLayout>
