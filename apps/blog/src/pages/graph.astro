---
import { getCollection } from 'astro:content';
import { BaseLayout, Graph as GraphView, type GraphViewModel } from '@noteforge/theme-default';
import obpubConfig from '../../noteforge.config.ts';
import { getPipelineResult } from '../lib/pipelineCache.ts';
import { ensureTrailingSlash } from '../lib/viewModels.ts';
import { buildSidebarPayload } from '../lib/sidebarPayload.ts';
import '../styles/global.css';

const result = await getPipelineResult();
const canonicalUrl = ensureTrailingSlash(
  new URL(Astro.url.pathname, Astro.site).toString(),
);
const sidebar = buildSidebarPayload(
  await getCollection('notes'),
  undefined,
  obpubConfig.nav.mode,
);

function lastSegment(slug: string): string {
  const i = slug.lastIndexOf('/');
  return i === -1 ? slug : slug.slice(i + 1);
}

const view: GraphViewModel = {
  nodes: result.publicGraph.nodes.map((slug) => {
    const fm = result.publicFrontmatter.get(slug);
    const fmTitle = fm !== undefined && typeof fm['title'] === 'string' ? (fm['title'] as string) : undefined;
    return { slug, title: fmTitle ?? lastSegment(slug) };
  }),
  edges: result.publicGraph.edges.map((e) => ({ source: e.from, target: e.to })),
};
---
<BaseLayout title="그래프" canonicalUrl={canonicalUrl} ogType="website" siteName={obpubConfig.site.title} sidebar={sidebar}>
  <GraphView graph={view} />
</BaseLayout>
