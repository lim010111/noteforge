---
import { getCollection } from 'astro:content';
import {
  AboutPage,
  BaseLayout,
  type AboutContent,
  type AboutIdentity,
} from '@noteforge/theme-default';
import obpubConfig from '../../noteforge.config.ts';
import { ensureTrailingSlash } from '../lib/viewModels.ts';
import { buildSidebarPayload } from '../lib/sidebarPayload.ts';
import { resolveSiteIdentity } from '../lib/siteIdentity.ts';
import '../styles/global.css';

// `resolveSiteIdentity` falls back to GitHub-derived avatar/nickname
// (https://github.com/<u>.png + username) when the config fields are unset
// but `site.social.github` is a github.com URL. `author` always stays the
// canonical real-name string from `siteSchema`.
const resolved = resolveSiteIdentity(obpubConfig.site);
const identity: AboutIdentity = { author: obpubConfig.site.author };
if (resolved.nickname !== undefined) {
  identity.nickname = resolved.nickname;
}
if (resolved.avatar !== undefined) {
  identity.avatar = resolved.avatar;
}
if (obpubConfig.site.social !== undefined) {
  identity.social = obpubConfig.site.social;
}

const aboutCfg = obpubConfig.site.about;
const about: AboutContent | undefined =
  aboutCfg === undefined
    ? undefined
    : {
        bio: aboutCfg.bio,
        highlights: aboutCfg.highlights,
        ...(aboutCfg.headline !== undefined ? { headline: aboutCfg.headline } : {}),
      };

const sidebar = buildSidebarPayload(
  await getCollection('notes'),
  undefined,
  obpubConfig.nav,
);
const canonicalUrl = ensureTrailingSlash(
  new URL(Astro.url.pathname, Astro.site).toString(),
);
---
<BaseLayout
  title="About"
  canonicalUrl={canonicalUrl}
  ogType="profile"
  siteName={obpubConfig.site.title}
  sidebar={sidebar}
>
  <AboutPage identity={identity} about={about} />
</BaseLayout>
