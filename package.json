{
  "name": "noteforge",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "Monorepo root for noteforge — privacy-first Astro SSG for selective Obsidian vault publishing.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "obpub": "pnpm --filter @noteforge/cli obpub",
    "vendor:fonts": "node scripts/vendor-fonts.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "astro": "^5.0.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^3.2.0",
    "wawoff2": "^2.0.1"
  }
}
